# ──────────────────────────────────────────────────────────────────
# khazna — .gitignore
# ──────────────────────────────────────────────────────────────────

# ── Vault data & secrets ──────────────────────────────────────────
vault.db
test_*.db
extension_secret
*.svbak
*.csv

# ── Logs ─────────────────────────────────────────────────────────
*.log
out.txt

# ── Python cache / bytecode ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env

# ── Build & packaging artifacts ──────────────────────────────────
build/
dist/
*.egg-info/
*.spec

# ── OS generated files ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editor settings ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Qt / PySide6 artifacts ───────────────────────────────────────
*.pyc
qmlcache/
.qmlc
